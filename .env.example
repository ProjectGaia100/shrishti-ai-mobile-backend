# Mobile backend service (HF2)
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=7860

# CORS
ALLOWED_ORIGINS=*

# Security
SCHEDULER_SECRET=change-me
MOBILE_CLIENT_API_KEY=

# Supabase (shared database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Local HazardGuard model runtime (same model family as HF1)
MODEL_REPO_ID=projectgaia/ShrishtiAI-models
MODEL_ROOT_PATH=
HF_TOKEN=
SKIP_MODEL_DOWNLOAD=false
DATASET_REPO_ID=shrishtiai/shrishtiai-geospatial-data
DATASET_LOCAL_DIR=

# Optional remote prediction fallback (unused when local HazardGuard is healthy)
MOBILE_HF_PREDICTION_URL=
MOBILE_HF_API_TOKEN=
MOBILE_HF_TIMEOUT_SECONDS=120
MOBILE_HF_BACKOFF_SECONDS=10,25,45,90

# Alert scheduler controls
MOBILE_ALERT_RISK_THRESHOLD=0.65
MOBILE_ALERT_FORECAST_HOURS=24
MOBILE_ALERT_BATCH_SIZE=5
